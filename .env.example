# Supabase — panel del proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: solo uso en servidor (scripts, seed, validación RLS). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — usado únicamente por lib/ai/embeddings.ts (servidor). Nunca exponer al cliente
# (por eso no lleva prefijo NEXT_PUBLIC_).
OPENAI_API_KEY=

# Anthropic — usado únicamente por lib/ai/chat.ts (servidor). Nunca exponer al cliente.
ANTHROPIC_API_KEY=
