{
  "name": "mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Servidor MCP de ReadHub: expone las capacidades de consulta de la plataforma como Tools, reutilizando la lógica compartida del monorepo.",
  "scripts": {
    "start": "tsx --conditions=react-server src/server.ts",
    "verify": "tsx --conditions=react-server src/verify-integration.ts",
    "verify:tools": "tsx --conditions=react-server src/verify-tools.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@readhub/ai": "*",
    "@readhub/database": "*",
    "@readhub/types": "*",
    "@readhub/shared": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
