# Supabase — panel del proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: solo uso en servidor (scripts, seed, validación RLS, apps/mcp). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Voyage AI — usado únicamente por packages/ai/src/embeddings.ts (servidor). Nunca exponer al
# cliente (por eso no lleva prefijo NEXT_PUBLIC_). voyageai.com, formato "pa-...".
VOYAGE_API_KEY=

# Groq — usado únicamente por packages/ai/src/chat.ts (servidor). Nunca exponer al cliente.
# console.groq.com, formato "gsk_...".
GROQ_API_KEY=

# Modelo de Groq, sobreescribible sin tocar código. Opcional: por defecto llama-3.3-70b-versatile.
GROQ_MODEL=

# --- Solo para los E2E de Playwright (apps/web/e2e/) ---------------------------
# Credenciales del usuario de prueba usado por el flujo de autenticación. Si se
# omiten, apps/web/e2e/data/users.ts usa por defecto el mismo fixture ya
# versionado en supabase/seed.sql (reader1@readhub.test / ReadHub123!), que debe
# existir realmente en el proyecto de Supabase señalado arriba (sembrado local
# vía `supabase db reset`, o creado igual en el proyecto remoto).
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
